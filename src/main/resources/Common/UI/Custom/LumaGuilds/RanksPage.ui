$C = "../Common.ui";

Group {
  Anchor: (Width: 700, Height: 550);
  Background: #141c26(0.98);
  LayoutMode: Top;
  Padding: (Full: 20);

  // Title
  Label {
    Text: "Ranks & Permissions";
    Anchor: (Height: 40);
    Style: (FontSize: 24, TextColor: #ffffff, HorizontalAlignment: Center, RenderBold: true);
  }

  // Separator
  Group { Anchor: (Height: 1); Background: #2b3542; }
  Group { Anchor: (Height: 16); }

  // Rank list area
  Group #RankList {
    FlexWeight: 1;
    LayoutMode: Top;
    Padding: (Horizontal: 8);
  }

  // Footer with buttons
  Group { Anchor: (Height: 12); }
  Group {
    LayoutMode: Left;
    Anchor: (Height: 44);

    $C.@SecondaryTextButton #BackBtn {
      @Text = "Back";
      Anchor: (Width: 100, Height: 40);
    }

    Group { FlexWeight: 1; }

    $C.@TextButton #AddRankBtn {
      @Text = "Add Rank";
      Anchor: (Width: 120, Height: 40);
    }
  }

  Group { Anchor: (Height: 8); }
  Label {
    Text: "Press ESC to close";
    Anchor: (Height: 16);
    Style: (FontSize: 11, TextColor: #555555, HorizontalAlignment: Center);
  }
}
